# Target Instagram profile (without @)
TARGET_PROFILE=findinggoodmovie.s

# Scroll delay range in milliseconds (randomized between min and max)
SCROLL_DELAY_MIN=1500
SCROLL_DELAY_MAX=3000

# Delay between yt-dlp downloads in milliseconds
DOWNLOAD_DELAY_MIN=3000
DOWNLOAD_DELAY_MAX=8000

# Max comments to extract per reel
MAX_COMMENTS=10

# Max consecutive scrolls with no new content before stopping
MAX_STALE_SCROLLS=8

# yt-dlp cookies file path (auto-generated by Phase 1)
COOKIES_FILE=cookies.txt

# Output directory
OUTPUT_DIR=output

# ═══════════════════════════════════════════════════
# AI Tag Generation — At least 1 API key required
# Priority: NVIDIA → Gemini → OpenRouter
# ═══════════════════════════════════════════════════

# NVIDIA API — Get from https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-405b-instruct

# Google Gemini API — Get from https://aistudio.google.com
GEMINI_API_KEY=


# OpenRouter API — Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=
